# Скопируй в .env (локально) или добавь как Environment Variables на Render

TELEGRAM_BOT_TOKEN=123456:AA...your_bot_token
TELEGRAM_CHAT_ID=123456789

# Вариант A (рекомендуется для Render): одной строкой содержимое serviceAccountKey.json
# ВАЖНО: вставляй как одну строку JSON, без переносов.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Вариант B (локально): положи файл serviceAccountKey.json рядом с bridge.py
